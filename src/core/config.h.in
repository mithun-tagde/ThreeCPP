// ============= Assertions Macro =============

#if THREECPP_ENABLE_ASSERTIONS || defined(_DEBUG)
    #include <cassert>
    #define THREECPP_ASSERT(condition, message) assert((condition) && (message))
#else
    #define THREECPP_ASSERT(condition, message) ((void)0)
#endif

// ============= Deprecation Macro =============

#if defined(__GNUC__) || defined(__clang__)
    #define THREECPP_DEPRECATED(msg) __attribute__((deprecated(msg)))
#elif defined(_MSC_VER)
    #define THREECPP_DEPRECATED(msg) __declspec(deprecated(msg))
#else
    #define THREECPP_DEPRECATED(msg)
#endif
